<h1> Game Code: <%= @game.code %> </h1>
<%= turbo_stream_from @game %>

<div data-controller="game">
  <h2> Players </h2>
  <%= render partial: 'games/players', locals: { players: @game.players } %>

  <% if @game.host == @user_id %>
    <button data-action="game#start">Start Game</button>
  <% end %>
</div>
