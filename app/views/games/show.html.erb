<%= render layout: 'layouts/container' do |game, user_id| %>

  <turbo-frame id="<%= dom_id(@game, :players) %>">
    <%= render partial: 'games/players', locals: { game: @game, players: @game.players } %>
  </turbo-frame>

  <%= form_with url: ready_game_path(code: @game.code), html: { class: ('hidden' unless game.host == user_id) } do |form| %>
    <%= form.submit 'Ready!' %>
  <% end %>
<% end %>
