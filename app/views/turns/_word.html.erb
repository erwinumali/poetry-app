<div
  class="card <%= scored ? 'scored' : 'unscored' %> <%= unclickable ? 'unclickable' : '' %>"
  data-turn-target="word"
  data-action="click->turn#<%= scored ? 'unscore' : 'score' %>"
  data-turn-word-param="<%= word %>"
>

  <div class="difficulty"><%= "#{difficulty.to_s.upcase} (#{difficulty == :easy ? '+1' : '+3'})" %></div>
  <div class="word"><%= word.upcase %></div>
</div>

